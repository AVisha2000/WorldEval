{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldeval.local/llm-controller/0.2.0/transport-frame.v1.schema.json",
  "title": "LLM Controller authenticated authority frame v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol_version", "episode_id", "sender", "sequence", "message_type", "boundary_hash_kind", "boundary_hash", "body", "auth_tag"],
  "properties": {
    "schema_version": {"const": "llm-controller/transport-frame/1.0.0"},
    "protocol_version": {"const": "llm-controller/0.2.0"},
    "episode_id": {"type": "string", "pattern": "^ep_[A-Za-z0-9._-]{1,120}$"},
    "sender": {"enum": ["python", "godot"]},
    "sequence": {"type": "integer", "minimum": 0, "maximum": 9007199254740991},
    "message_type": {"enum": ["hello", "auth", "episode_ready", "decision_window", "step_result", "frame_request", "frame_response", "close_episode", "episode_closed", "episode_error"]},
    "boundary_hash_kind": {"enum": ["session", "config", "checkpoint"]},
    "boundary_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "body": {"type": "object"},
    "auth_tag": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
