{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldeval.local/llm-controller/0.3.0/multi-participant-step-result.v1.schema.json",
  "title": "LLM Controller exactly-three-participant step result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "observations",
    "receipts",
    "public_events",
    "state_hash",
    "terminal",
    "placements",
    "trio_result"
  ],
  "properties": {
    "observations": {
      "$ref": "https://worldeval.local/llm-controller/0.3.0/multi-participant-step-result.v1.schema.json#/$defs/observations"
    },
    "receipts": {
      "$ref": "https://worldeval.local/llm-controller/0.3.0/multi-participant-step-result.v1.schema.json#/$defs/receipts"
    },
    "public_events": {
      "type": "array",
      "maxItems": 256,
      "items": {
        "$ref": "https://worldeval.local/llm-controller/0.3.0/authority-event.v1.schema.json"
      }
    },
    "state_hash": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "terminal": {
      "$ref": "https://worldeval.local/llm-controller/0.3.0/multi-participant-step-result.v1.schema.json#/$defs/terminal"
    },
    "placements": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "$ref": "https://worldeval.local/llm-controller/0.3.0/trio-result.v1.schema.json#/$defs/placement_group"
      }
    },
    "trio_result": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "https://worldeval.local/llm-controller/0.3.0/trio-result.v1.schema.json"
        }
      ]
    }
  },
  "$defs": {
    "observations": {
      "type": "object",
      "minProperties": 3,
      "maxProperties": 3,
      "required": [
        "participant_0",
        "participant_1",
        "participant_2"
      ],
      "additionalProperties": {
        "$ref": "https://worldeval.local/llm-controller/0.3.0/observation.v1.schema.json"
      }
    },
    "receipts": {
      "type": "object",
      "minProperties": 3,
      "maxProperties": 3,
      "required": [
        "participant_0",
        "participant_1",
        "participant_2"
      ],
      "additionalProperties": {
        "$ref": "https://worldeval.local/llm-controller/0.3.0/action-receipt.v1.schema.json"
      }
    },
    "terminal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ended",
        "outcome",
        "reason"
      ],
      "properties": {
        "ended": {
          "type": "boolean"
        },
        "outcome": {
          "enum": [
            "running",
            "win",
            "draw",
            "void"
          ]
        },
        "reason": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{0,63}$"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "terminal": {
            "properties": {
              "ended": {
                "const": false
              }
            },
            "required": [
              "ended"
            ]
          }
        },
        "required": [
          "terminal"
        ]
      },
      "then": {
        "properties": {
          "placements": {
            "maxItems": 0
          },
          "trio_result": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "terminal": {
            "properties": {
              "ended": {
                "const": true
              }
            },
            "required": [
              "ended"
            ]
          }
        },
        "required": [
          "terminal"
        ]
      },
      "then": {
        "properties": {
          "placements": {
            "minItems": 1
          },
          "trio_result": {
            "$ref": "https://worldeval.local/llm-controller/0.3.0/trio-result.v1.schema.json"
          }
        }
      }
    }
  ]
}
