{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldeval.local/llm-controller/0.3.0/episode-config.v1.schema.json",
  "title": "LLM Controller trio episode configuration v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "episode_id",
    "mode",
    "task_id",
    "seed",
    "observation_profile",
    "timing_track",
    "maximum_episode_ticks",
    "participant_ids",
    "seat_rotation"
  ],
  "properties": {
    "protocol_version": {
      "const": "llm-controller/0.3.0"
    },
    "episode_id": {
      "type": "string",
      "pattern": "^ep_[A-Za-z0-9._-]{1,120}$"
    },
    "mode": {
      "const": "trio-game-v0"
    },
    "task_id": {
      "enum": [
        "trio-relay-v0",
        "trio-free-for-all-v0"
      ]
    },
    "seed": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "observation_profile": {
      "enum": [
        "text-visible-v1",
        "hybrid-visible-v1"
      ]
    },
    "timing_track": {
      "const": "step-locked-v1"
    },
    "maximum_episode_ticks": {
      "const": 1200
    },
    "participant_ids": {
      "const": [
        "participant_0",
        "participant_1",
        "participant_2"
      ]
    },
    "seat_rotation": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    }
  }
}
