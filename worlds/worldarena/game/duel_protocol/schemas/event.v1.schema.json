{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldeval.dev/schemas/event.v1.schema.json",
  "title": "WorldArena Duel observable event v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_seq", "tick", "kind", "audience", "payload"],
  "properties": {
    "event_seq": {"type": "integer", "minimum": 1},
    "tick": {"type": "integer", "minimum": 0},
    "kind": {
      "enum": [
        "entity_created",
        "entity_entered_vision",
        "entity_left_vision",
        "entity_reacquired",
        "entity_transformed",
        "entity_destroyed",
        "attack_observed",
        "damage_observed",
        "healing_observed",
        "cast_observed",
        "status_started",
        "status_ended",
        "item_picked_up",
        "item_dropped",
        "resource_deposited",
        "resource_spent",
        "resource_refunded",
        "upkeep_changed",
        "order_started",
        "order_completed",
        "order_cancelled",
        "order_paused",
        "order_failed",
        "construction_progress",
        "construction_completed",
        "repair_progress",
        "production_progress",
        "production_completed",
        "research_progress",
        "research_completed",
        "tier_completed",
        "revival_progress",
        "revival_completed",
        "hero_xp_gained",
        "hero_level_gained",
        "hero_skill_learned",
        "creep_camp_cleared",
        "camp_item_revealed",
        "shop_restocked",
        "shop_purchase",
        "day_phase_changed",
        "resource_depleted",
        "terrain_changed",
        "pathing_changed",
        "batch_timeout",
        "batch_schema_failed",
        "command_applied",
        "command_rejected",
        "terminal_win",
        "terminal_loss",
        "terminal_draw",
        "terminal_forfeit",
        "terminal_infrastructure_void"
      ]
    },
    "audience": {"enum": ["self", "opponent", "omniscient"]},
    "payload": {"$ref": "#/$defs/payload"}
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"},
    "point": {
      "type": "array",
      "prefixItems": [{"type": "integer"}, {"type": "integer"}],
      "items": false,
      "minItems": 2,
      "maxItems": 2,
      "x-canonical-order": "coordinate-x-y"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entity_id": {"$ref": "#/$defs/id"},
        "source_entity_id": {"$ref": "#/$defs/id"},
        "target_entity_id": {"$ref": "#/$defs/id"},
        "type_id": {"$ref": "#/$defs/id"},
        "previous_type_id": {"$ref": "#/$defs/id"},
        "site_id": {"$ref": "#/$defs/id"},
        "region_id": {"$ref": "#/$defs/id"},
        "position_mt": {"$ref": "#/$defs/point"},
        "resource": {"enum": ["gold", "lumber", "food", "mana", "hp"]},
        "amount": {"type": "integer"},
        "damage": {"type": "integer", "minimum": 0},
        "healing": {"type": "integer", "minimum": 0},
        "progress_bp": {"type": "integer", "minimum": 0, "maximum": 10000},
        "status_id": {"$ref": "#/$defs/id"},
        "ability_id": {"$ref": "#/$defs/id"},
        "item_id": {"$ref": "#/$defs/id"},
        "upgrade_id": {"$ref": "#/$defs/id"},
        "offer_id": {"$ref": "#/$defs/id"},
        "queue_entry_id": {"$ref": "#/$defs/id"},
        "batch_id": {"$ref": "#/$defs/id"},
        "command_id": {"$ref": "#/$defs/id"},
        "compiled_order_id": {"$ref": "#/$defs/id"},
        "code": {"type": ["string", "null"], "maxLength": 64},
        "day_phase": {"enum": ["day", "night", "forced_night"]},
        "terminal_reason": {"type": "string", "maxLength": 80},
        "winner": {"enum": ["self", "opponent", "none"]},
        "tier": {"type": "integer", "minimum": 1, "maximum": 3},
        "level": {"type": "integer", "minimum": 1, "maximum": 10},
        "xp": {"type": "integer", "minimum": 0},
        "details": {
          "type": "array",
          "maxItems": 24,
          "x-canonical-order": "ascending-id",
          "items": {"$ref": "#/$defs/id"}
        }
      }
    }
  }
}
