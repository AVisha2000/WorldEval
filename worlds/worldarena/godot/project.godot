; Engine configuration file.
; Best edited using the editor, but intentionally kept small and portable.

config_version=5

[application]

config/name="WorldArena"
run/main_scene="res://scenes/arena_v1.tscn"

[display]

window/size/viewport_width=1440
window/size/viewport_height=900
window/size/window_width_override=1440
window/size/window_height_override=900
window/stretch/mode="canvas_items"
window/size/viewport_width.movie=1920
window/size/viewport_height.movie=1080
window/size/window_width_override.movie=1280
window/size/window_height_override.movie=720
window/stretch/mode.movie="viewport"

[debug]

file_logging/enable_file_logging=false
file_logging/enable_file_logging.pc=false

[editor_plugins]

enabled=PackedStringArray("res://addons/terrain_3d/plugin.cfg")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=false
environment/defaults/default_clear_color=Color(0.025, 0.045, 0.07, 1)
