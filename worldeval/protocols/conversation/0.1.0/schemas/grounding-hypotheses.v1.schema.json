{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldeval.local/conversation/0.1.0/grounding-hypotheses.v1.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "protocol", "hypothesis_set_id", "task_id", "conversation_id", "command_message_id", "source", "status", "candidates"],
  "properties": {
    "schema_version": {"const": "grounding-hypotheses.v1"}, "protocol": {"$ref": "common.v1.schema.json#/$defs/protocol"},
    "hypothesis_set_id": {"$ref": "common.v1.schema.json#/$defs/id"}, "task_id": {"$ref": "common.v1.schema.json#/$defs/id"},
    "conversation_id": {"$ref": "common.v1.schema.json#/$defs/id"}, "command_message_id": {"$ref": "common.v1.schema.json#/$defs/id"},
    "source": {"$ref": "common.v1.schema.json#/$defs/source"},
    "status": {"enum": ["resolved", "ambiguous", "unresolved"]}, "selected_candidate_id": {"$ref": "common.v1.schema.json#/$defs/id"},
    "candidates": {"type": "array", "minItems": 1, "maxItems": 16, "items": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate_id", "entity", "visible_evidence"],
      "properties": {"candidate_id": {"$ref": "common.v1.schema.json#/$defs/id"}, "entity": {"$ref": "common.v1.schema.json#/$defs/entity"}, "visible_evidence": {"$ref": "common.v1.schema.json#/$defs/visibleEvidence"}}
    }}
  }
}
