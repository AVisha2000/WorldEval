{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldeval.local/agent/0.1.0/replay-bundle.v1.schema.json",
  "title": "WorldEval agent native replay descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol", "run_id", "environment_id", "scenario_id", "initialization_hash", "initial_state_hash", "terminal_state_hash", "terminal_outcome", "terminal_tick", "authority_metrics", "decisions", "observations", "receipts", "provider_calls", "offline_verified"],
  "properties": {
    "schema_version": {"const": "replay-bundle.v1"}, "protocol": {"$ref": "common.v1.schema.json#/$defs/protocol"},
    "run_id": {"$ref": "common.v1.schema.json#/$defs/id"}, "environment_id": {"$ref": "common.v1.schema.json#/$defs/id"}, "scenario_id": {"$ref": "common.v1.schema.json#/$defs/id"},
    "initialization_hash": {"$ref": "common.v1.schema.json#/$defs/hash"}, "initial_state_hash": {"$ref": "common.v1.schema.json#/$defs/hash"}, "terminal_state_hash": {"$ref": "common.v1.schema.json#/$defs/hash"},
    "terminal_outcome": {"type": "string"}, "terminal_tick": {"type": "integer", "minimum": 0},
    "authority_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forbidden_autonomy_count", "hostile_attacks"],
      "properties": {
        "forbidden_autonomy_count": {"type": "integer", "minimum": 0},
        "hostile_attacks": {"type": "integer", "minimum": 0}
      }
    },
    "decisions": {"type": "array", "items": {"oneOf": [{"$ref": "decision-response.v1.schema.json"}, {"type": "null"}]}},
    "observations": {"type": "array", "minItems": 1, "items": {"$ref": "observation.v1.schema.json"}},
    "receipts": {"type": "array", "items": {"$ref": "action-receipt.v1.schema.json"}},
    "provider_calls": {"const": 0}, "offline_verified": {"type": "boolean"}
  }
}
