{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldeval.local/agent/0.1.0/decision-response.v1.schema.json",
  "title": "WorldEval agent decision response v1",
  "oneOf": [
    {
      "type": "object", "additionalProperties": false, "required": ["type", "plan_id", "source", "lease_ticks"],
      "properties": {"type": {"const": "plan.continue"}, "plan_id": {"$ref": "common.v1.schema.json#/$defs/id"}, "source": {"$ref": "common.v1.schema.json#/$defs/source"}, "lease_ticks": {"type": "integer", "minimum": 1, "maximum": 50}}
    },
    {
      "type": "object", "additionalProperties": false, "required": ["type", "replaces_plan_id", "plan"],
      "properties": {"type": {"const": "plan.replace"}, "replaces_plan_id": {"oneOf": [{"$ref": "common.v1.schema.json#/$defs/id"}, {"type": "null"}]}, "plan": {"$ref": "action-plan.v1.schema.json"}}
    },
    {
      "type": "object", "additionalProperties": false, "required": ["type", "plan_id", "source", "reason"],
      "properties": {"type": {"const": "plan.abort"}, "plan_id": {"$ref": "common.v1.schema.json#/$defs/id"}, "source": {"$ref": "common.v1.schema.json#/$defs/source"}, "reason": {"type": "string", "minLength": 1, "maxLength": 500}}
    },
    {
      "type": "object", "additionalProperties": false, "required": ["type", "source", "maximum_ticks", "until"],
      "properties": {"type": {"const": "wait"}, "source": {"$ref": "common.v1.schema.json#/$defs/source"}, "maximum_ticks": {"type": "integer", "minimum": 1, "maximum": 50}, "until": {"type": "array", "maxItems": 32, "items": {"$ref": "common.v1.schema.json#/$defs/id"}}}
    }
  ]
}
