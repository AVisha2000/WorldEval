{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldeval.local/agent/0.1.0/action-receipt.v1.schema.json",
  "title": "WorldEval agent action receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol", "receipt_id", "observation_seq", "response_type", "plan_id", "step_id", "accepted", "disposition", "fallback", "no_input_reason", "start_tick", "end_tick", "applied_ticks", "codes", "effects"],
  "properties": {
    "schema_version": {"const": "action-receipt.v1"}, "protocol": {"$ref": "common.v1.schema.json#/$defs/protocol"},
    "receipt_id": {"$ref": "common.v1.schema.json#/$defs/id"}, "observation_seq": {"type": "integer", "minimum": 0},
    "response_type": {"type": ["string", "null"], "enum": [null, "plan.continue", "plan.replace", "plan.abort", "wait"]},
    "plan_id": {"oneOf": [{"$ref": "common.v1.schema.json#/$defs/id"}, {"type": "null"}]}, "step_id": {"oneOf": [{"$ref": "common.v1.schema.json#/$defs/id"}, {"type": "null"}]},
    "accepted": {"type": "boolean"}, "disposition": {"enum": ["accepted", "no_input", "rejected"]}, "fallback": {"enum": ["none", "neutral"]},
    "no_input_reason": {"type": ["string", "null"], "enum": [null, "missing", "invalid", "timeout", "stale_observation", "stale_tick", "stale_state"]},
    "start_tick": {"type": "integer", "minimum": 0}, "end_tick": {"type": "integer", "minimum": 0}, "applied_ticks": {"type": "integer", "minimum": 0, "maximum": 50},
    "codes": {"type": "array", "maxItems": 32, "items": {"$ref": "common.v1.schema.json#/$defs/id"}, "uniqueItems": true},
    "effects": {
      "type": "array", "maxItems": 256,
      "items": {
        "type": "object", "additionalProperties": false, "required": ["kind", "object_id", "data"],
        "properties": {"kind": {"$ref": "common.v1.schema.json#/$defs/id"}, "object_id": {"oneOf": [{"$ref": "common.v1.schema.json#/$defs/id"}, {"type": "null"}]}, "data": {"type": "object"}}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"accepted": {"const": true}}, "required": ["accepted"]},
      "then": {"properties": {"disposition": {"const": "accepted"}, "fallback": {"const": "none"}, "no_input_reason": {"type": "null"}}}
    },
    {
      "if": {"properties": {"fallback": {"const": "neutral"}}, "required": ["fallback"]},
      "then": {"properties": {"accepted": {"const": false}, "disposition": {"const": "no_input"}, "no_input_reason": {"type": "string"}}}
    }
  ]
}
