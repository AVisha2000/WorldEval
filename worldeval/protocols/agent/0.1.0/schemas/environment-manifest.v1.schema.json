{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldeval.local/agent/0.1.0/environment-manifest.v1.schema.json",
  "title": "WorldEval agent environment manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol", "environment_id", "game_id", "name", "briefing", "authority", "profiles", "coordinate_frames", "controllable_asset_types", "object_catalog", "action_catalog", "decision_profile", "contracts", "example_traces", "semantic_world_commands_exposed", "exact_world_coordinates_exposed"],
  "properties": {
    "schema_version": {"const": "environment-manifest.v1"},
    "protocol": {"$ref": "common.v1.schema.json#/$defs/protocol"},
    "environment_id": {"$ref": "common.v1.schema.json#/$defs/id"},
    "game_id": {"$ref": "common.v1.schema.json#/$defs/id"},
    "name": {"type": "string", "minLength": 1, "maxLength": 120},
    "briefing": {"$ref": "common.v1.schema.json#/$defs/briefing"},
    "authority": {"$ref": "common.v1.schema.json#/$defs/authority"},
    "profiles": {"$ref": "common.v1.schema.json#/$defs/profiles"},
    "coordinate_frames": {"type": "array", "minItems": 1, "maxItems": 8, "items": {"$ref": "common.v1.schema.json#/$defs/coordinateFrame"}},
    "controllable_asset_types": {"type": "array", "minItems": 1, "maxItems": 32, "items": {"$ref": "common.v1.schema.json#/$defs/id"}},
    "object_catalog": {"type": "string"}, "action_catalog": {"type": "string"}, "decision_profile": {"type": "string"},
    "contracts": {"$ref": "common.v1.schema.json#/$defs/contracts"},
    "example_traces": {"type": "array", "maxItems": 32, "items": {"type": "string"}},
    "semantic_world_commands_exposed": {"const": true}, "exact_world_coordinates_exposed": {"const": true}
  }
}
