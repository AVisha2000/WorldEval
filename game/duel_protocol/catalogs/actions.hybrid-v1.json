{
  "catalog_id": "actions.hybrid-v1",
  "protocol_version": "worldeval-rts/1.0.0",
  "control_profile": "hybrid-v1",
  "schema_id": "https://worldeval.dev/schemas/action-batch.v1.schema.json",
  "limits": {
    "max_command_objects": 16,
    "max_atomic_order_cost": 64,
    "max_actor_ids_per_command": 24,
    "max_squad_members": 24,
    "max_queue_entries_per_entity": 8,
    "max_output_bytes": 16384,
    "max_working_memory_bytes": 4096,
    "max_intent_summary_codepoints": 240
  },
  "queue_semantics": {
    "replace": "clear_interruptible_then_issue",
    "append": "enqueue_after_existing",
    "front": "interrupt_and_prepend_restricted"
  },
  "front_allowed_for": ["cast", "retreat", "stop", "use_item"],
  "target_forms": {
    "entity": ["kind", "entity_id"],
    "point": ["kind", "xy_mt"],
    "region_slot": ["kind", "region_id", "slot_id"],
    "site": ["kind", "site_id"]
  },
  "operations": {
    "attack_entity": {"category": "combat", "required": ["actor_ids", "target", "queue"], "optional": [], "target_forms": ["entity"], "atomic_cost": "actor_count"},
    "attack_ground": {"category": "combat", "required": ["actor_ids", "target", "queue"], "optional": [], "target_forms": ["point"], "atomic_cost": "actor_count"},
    "attack_move": {"category": "combat", "required": ["actor_ids", "target", "queue"], "optional": [], "target_forms": ["point", "region_slot"], "atomic_cost": "actor_count"},
    "build": {"category": "economy", "required": ["builder_ids", "building_type_id", "build_site_id"], "optional": [], "target_forms": [], "atomic_cost": "builder_count"},
    "cancel_construction": {"category": "economy", "required": ["building_id"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "cancel_queue": {"category": "economy", "required": ["producer_id", "queue_entry_id"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "cast": {"category": "ability", "required": ["actor_id", "ability_id", "queue"], "optional": ["target"], "target_forms": ["entity", "point", "region_slot", "site"], "atomic_cost": "one"},
    "define_squad": {"category": "squad", "required": ["squad_id", "member_ids"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "disband_squad": {"category": "squad", "required": ["squad_id"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "drop_item": {"category": "item", "required": ["hero_id", "item_instance_id", "target"], "optional": [], "target_forms": ["point"], "atomic_cost": "one"},
    "follow": {"category": "movement", "required": ["actor_ids", "target", "distance_mt", "queue"], "optional": [], "target_forms": ["entity"], "atomic_cost": "actor_count"},
    "gather": {"category": "economy", "required": ["worker_ids", "resource_target", "queue"], "optional": [], "target_forms": ["entity", "site"], "atomic_cost": "worker_count"},
    "hold_position": {"category": "combat", "required": ["actor_ids"], "optional": [], "target_forms": [], "atomic_cost": "actor_count"},
    "learn_ability": {"category": "ability", "required": ["hero_id", "ability_id"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "load_transport": {"category": "transport", "required": ["transport_id", "passenger_ids", "queue"], "optional": [], "target_forms": [], "atomic_cost": "passenger_count"},
    "move": {"category": "movement", "required": ["actor_ids", "target", "queue"], "optional": [], "target_forms": ["point", "region_slot"], "atomic_cost": "actor_count"},
    "order_squad": {"category": "squad", "required": ["squad_id", "objective", "target", "formation", "engagement", "queue"], "optional": [], "target_forms": ["entity", "point", "region_slot", "site"], "atomic_cost": "current_squad_member_count"},
    "patrol": {"category": "movement", "required": ["actor_ids", "targets", "queue"], "optional": [], "target_forms": ["point", "region_slot"], "atomic_cost": "actor_count"},
    "pick_up_item": {"category": "item", "required": ["hero_id", "item_entity_id", "queue"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "produce": {"category": "economy", "required": ["producer_id", "unit_type_id", "quantity"], "optional": [], "target_forms": [], "atomic_cost": "quantity"},
    "purchase_offer": {"category": "item", "required": ["buyer_id", "shop_id", "offer_id", "quantity"], "optional": ["service_target"], "target_forms": ["point", "region_slot"], "atomic_cost": "quantity"},
    "repair": {"category": "economy", "required": ["worker_ids", "target", "queue"], "optional": [], "target_forms": ["entity"], "atomic_cost": "worker_count"},
    "research": {"category": "economy", "required": ["producer_id", "upgrade_id"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "retreat": {"category": "movement", "required": ["actor_ids", "target", "queue"], "optional": [], "target_forms": ["entity", "site"], "atomic_cost": "actor_count"},
    "return_cargo": {"category": "economy", "required": ["worker_ids", "queue"], "optional": ["deposit_target"], "target_forms": ["entity"], "atomic_cost": "worker_count"},
    "revive_hero": {"category": "hero", "required": ["reviver_id", "hero_id", "revival_method"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "sell_item": {"category": "item", "required": ["hero_id", "shop_id", "item_instance_id"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "set_autocast": {"category": "ability", "required": ["actor_ids", "ability_id", "enabled"], "optional": [], "target_forms": [], "atomic_cost": "actor_count"},
    "set_rally": {"category": "economy", "required": ["producer_id", "target"], "optional": [], "target_forms": ["entity", "point", "region_slot", "site"], "atomic_cost": "one"},
    "set_stance": {"category": "combat", "required": ["actor_ids", "stance"], "optional": [], "target_forms": [], "atomic_cost": "actor_count"},
    "set_tactics": {"category": "squad", "required": ["subject", "formation", "stance", "focus_tag", "retreat_hp_threshold_bp"], "optional": ["retreat_target"], "target_forms": ["entity", "site"], "atomic_cost": "affected_actor_count"},
    "stop": {"category": "movement", "required": ["actor_ids"], "optional": [], "target_forms": [], "atomic_cost": "actor_count"},
    "transfer_item": {"category": "item", "required": ["from_hero_id", "to_hero_id", "item_instance_id"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "unload_transport": {"category": "transport", "required": ["transport_id", "passengers", "target"], "optional": [], "target_forms": ["point"], "atomic_cost": "passenger_count"},
    "update_squad": {"category": "squad", "required": ["squad_id", "member_ids"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "upgrade_tier": {"category": "economy", "required": ["stronghold_id", "target_tier"], "optional": [], "target_forms": [], "atomic_cost": "one"},
    "use_item": {"category": "item", "required": ["hero_id", "item_instance_id", "queue"], "optional": ["target"], "target_forms": ["entity", "point", "region_slot", "site"], "atomic_cost": "one"}
  },
  "squad_objectives": ["attack_move_to", "focus_visible_entity", "hold_area", "move_to", "patrol_points", "retreat_to"],
  "formations": ["compact", "line", "none", "spread", "wedge"],
  "stances": ["aggressive", "defensive", "hold_fire", "hold_position"],
  "atomic_budget_policy": "reject_first_over_budget_and_all_later_commands",
  "invalid_envelope_policy": "whole_batch_no_op",
  "illegal_command_policy": "skip_command_continue_batch"
}
