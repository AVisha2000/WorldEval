# The deterministic demo brain is the safe default and needs no credentials.
GENESIS_BRAIN_MODE=demo

# Arena v1 credentials are entered in the in-game setup screen and held in memory only.
# Do not add API keys to this file.

GENESIS_OPENAI_MODEL=gpt-5.6-sol
GENESIS_REASONING_EFFORT=low
GENESIS_HOST=127.0.0.1
GENESIS_PORT=8000
GENESIS_DECISION_TIMEOUT_SECONDS=45
